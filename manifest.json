{
  "manifest_version": 3,
  "name": "Claude Usage Monitor",
  "version": "1.0.0",
  "description": "Track Claude.ai usage limits — utilization bars, goals, heatmap, IoT push.",
  "permissions": ["storage", "alarms", "notifications", "tabs"],
  "host_permissions": [
    "https://claude.ai/*",
    "http://192.168.*/*",
    "http://10.*/*",
    "http://172.16.*/*",
    "http://172.17.*/*",
    "http://172.18.*/*",
    "http://172.19.*/*",
    "http://172.20.*/*",
    "http://172.21.*/*",
    "http://172.22.*/*",
    "http://172.23.*/*",
    "http://172.24.*/*",
    "http://172.25.*/*",
    "http://172.26.*/*",
    "http://172.27.*/*",
    "http://172.28.*/*",
    "http://172.29.*/*",
    "http://172.30.*/*",
    "http://172.31.*/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Claude Usage",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
